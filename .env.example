# DigitalOcean Spaces Configuration
# Copy this file to .env and fill in your actual credentials
# DO NOT commit .env to git!

AWS__AccessKey=your_digitalocean_spaces_access_key
AWS__SecretKey=your_digitalocean_spaces_secret_key
AWS__ServiceURL=https://your-region.digitaloceanspaces.com

# Database Configuration
# Generate strong passwords using: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_DATABASE=memes
MYSQL_USER=memeservice
MYSQL_PASSWORD=your_secure_app_password_here